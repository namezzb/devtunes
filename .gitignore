node_modules/
*/node_modules/

# Build outputs
dist/
*/dist/
.vite/
*/.vite/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
*/npm-debug.log*

# Environment
.env
.env.local
.env.*.local

# Cache
.cache/
*/.cache/
.parcel-cache/

# TypeScript
*.tsbuildinfo
*/*.tsbuildinfo

# Test coverage
coverage/
*/coverage/

# Test artifacts
test-results/
frontend/test-results/
frontend/playwright-report/

# Playwright
.playwright-cli/
.playwright-mcp/

# Data / local caches
data/

# Misc
*.tgz

# Local development
bugfixes/
backend/check_path.ts
frontend/CODE_REVIEW.md
